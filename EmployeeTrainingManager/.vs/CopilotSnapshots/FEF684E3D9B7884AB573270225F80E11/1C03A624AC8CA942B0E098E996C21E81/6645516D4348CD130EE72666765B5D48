<Window x:Class="EmployeeTrainingManager.Presentation.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:EmployeeTrainingManager.Presentation"
        mc:Ignorable="d"
        Title="Employee Training Manager" Height="700" Width="1200" WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Employee Training Manager" FontSize="24" FontWeight="Bold" VerticalAlignment="Center"/>
            <Button Name="RefreshButton" Content="Refresh All" Click="RefreshButton_Click" Margin="20,0,0,0" Padding="10,5" 
                    Background="#4CAF50" Foreground="White" BorderThickness="0" Cursor="Hand"/>
        </StackPanel>

        <TabControl Grid.Row="1">
            <!-- Employees Tab -->
            <TabItem Header="Employees">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <GroupBox Header="Employee List" Grid.Column="0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <DataGrid Name="EmployeeDataGrid" Grid.Row="0"
                                      AutoGenerateColumns="False" 
                                      IsReadOnly="True"
                                      SelectionMode="Single"
                                      SelectionChanged="EmployeeDataGrid_SelectionChanged"
                                      Margin="5">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="Auto"/>
                                    <DataGridTextColumn Header="First Name" Binding="{Binding FirstName}" Width="*"/>
                                    <DataGridTextColumn Header="Last Name" Binding="{Binding LastName}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>

                            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="5">
                                <Button Content="Delete Selected" Click="DeleteEmployeeButton_Click"
                                        Padding="10,5" Background="#F44336" Foreground="White" 
                                        BorderThickness="0" Cursor="Hand"/>
                            </StackPanel>
                        </Grid>
                    </GroupBox>

                    <GroupBox Header="Add New Employee" Grid.Column="2">
                        <StackPanel Margin="5">
                            <Label Content="First Name:"/>
                            <TextBox Name="FirstNameTextBox" Margin="0,0,0,10"/>

                            <Label Content="Last Name:"/>
                            <TextBox Name="LastNameTextBox" Margin="0,0,0,10"/>

                            <Button Content="Add Employee" Click="AddEmployeeButton_Click"
                                    Padding="10,8" Background="#2196F3" Foreground="White" 
                                    BorderThickness="0" Cursor="Hand" Margin="0,10,0,0"/>
                        </StackPanel>
                    </GroupBox>
                </Grid>
            </TabItem>

            <!-- Trainings Tab -->
            <TabItem Header="Trainings">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <GroupBox Header="Training List" Grid.Column="0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <ListBox Name="TrainingListBox" Grid.Row="0" Margin="5">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="5">
                                            <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="14"/>
                                            <TextBlock Text="{Binding TrainerName, StringFormat='Trainer: {0}'}" FontSize="11" Foreground="DarkGray"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="5">
                                <Button Content="Delete Selected" Click="DeleteTrainingButton_Click"
                                        Padding="10,5" Background="#F44336" Foreground="White" 
                                        BorderThickness="0" Cursor="Hand"/>
                            </StackPanel>
                        </Grid>
                    </GroupBox>

                    <GroupBox Header="Add New Training" Grid.Column="2">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="5">
                                <Label Content="Training Type:"/>
                                <ComboBox Name="TrainingTypeComboBox" SelectionChanged="TrainingTypeComboBox_SelectionChanged" Margin="0,0,0,10">
                                    <ComboBoxItem Content="Technical" IsSelected="True"/>
                                    <ComboBoxItem Content="Safety"/>
                                </ComboBox>

                                <Label Content="Training ID:"/>
                                <TextBox Name="TrainingIdTextBox" Margin="0,0,0,10"/>

                                <Label Content="Title:"/>
                                <TextBox Name="TrainingTitleTextBox" Margin="0,0,0,10"/>

                                <Label Content="Trainer Name:"/>
                                <TextBox Name="TrainerNameTextBox" Margin="0,0,0,10"/>

                                <StackPanel Name="TechnicalFieldsPanel">
                                    <Label Content="Technology:"/>
                                    <TextBox Name="TechnologyTextBox" Margin="0,0,0,10"/>
                                </StackPanel>

                                <StackPanel Name="SafetyFieldsPanel" Visibility="Collapsed">
                                    <Label Content="Duration (Hours):"/>
                                    <TextBox Name="DurationTextBox" Margin="0,0,0,10"/>

                                    <Label Content="Risk Level:"/>
                                    <ComboBox Name="RiskLevelComboBox" Margin="0,0,0,10">
                                        <ComboBoxItem Content="Low"/>
                                        <ComboBoxItem Content="Medium"/>
                                        <ComboBoxItem Content="High"/>
                                    </ComboBox>
                                </StackPanel>

                                <Button Content="Add Training" Click="AddTrainingButton_Click"
                                        Padding="10,8" Background="#2196F3" Foreground="White" 
                                        BorderThickness="0" Cursor="Hand" Margin="0,10,0,0"/>
                            </StackPanel>
                        </ScrollViewer>
                    </GroupBox>
                </Grid>
            </TabItem>

            <!-- Enrollments Tab -->
            <TabItem Header="Enrollments">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <GroupBox Header="Enroll Employee in Training" Grid.Row="0">
                        <Grid Margin="5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <Label Content="Select Employee:"/>
                                <ComboBox Name="EmployeeComboBox" Height="30">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock>
                                                <Run Text="{Binding FirstName}"/>
                                                <Run Text=" "/>
                                                <Run Text="{Binding LastName}"/>
                                            </TextBlock>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <Label Content="Select Training:"/>
                                <ComboBox Name="TrainingComboBox" DisplayMemberPath="Title" Height="30"/>
                            </StackPanel>

                            <StackPanel Grid.Column="4" VerticalAlignment="Bottom">
                                <CheckBox Name="BillableCheckBox" Content="Billable" 
                                          VerticalAlignment="Center" Margin="0,5,0,0"/>
                            </StackPanel>

                            <StackPanel Grid.Column="6" VerticalAlignment="Bottom">
                                <Button Content="Enroll" Click="EnrollButton_Click"
                                        Padding="20,8" Background="#FF9800" Foreground="White" 
                                        BorderThickness="0" Cursor="Hand"/>
                            </StackPanel>
                        </Grid>
                    </GroupBox>

                    <GroupBox Header="Employee Enrollments" Grid.Row="2">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <DataGrid Name="EnrollmentDataGrid" Grid.Row="0" ItemsSource="{Binding Enrollments}" 
                                      AutoGenerateColumns="False" 
                                      IsReadOnly="True"
                                      Margin="5">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="Auto"/>
                                    <DataGridTextColumn Header="Employee" Width="*">
                                        <DataGridTextColumn.Binding>
                                            <MultiBinding StringFormat="{}{0} {1}">
                                                <Binding Path="Employee.FirstName"/>
                                                <Binding Path="Employee.LastName"/>
                                            </MultiBinding>
                                        </DataGridTextColumn.Binding>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="Training" Binding="{Binding Training.Title}" Width="*"/>
                                    <DataGridCheckBoxColumn Header="Billable" Binding="{Binding IsBillable}" Width="Auto"/>
                                </DataGrid.Columns>
                            </DataGrid>

                            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="5">
                                <Button Content="Delete Selected" Click="DeleteEnrollmentButton_Click"
                                        Padding="10,5" Background="#F44336" Foreground="White" 
                                        BorderThickness="0" Cursor="Hand"/>
                            </StackPanel>
                        </Grid>
                    </GroupBox>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
